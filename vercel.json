{
  "version": 2,
  "builds": [
    {
      "src": "frontend/labsim/others/rocketsimulator/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "frontend/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/labsim/others/rocketsimulator/(.*)",
      "dest": "frontend/labsim/others/rocketsimulator/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
